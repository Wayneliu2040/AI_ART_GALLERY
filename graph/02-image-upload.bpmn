        <dc:Bounds x="650" y="268" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_FillUploadForm" bpmnElement="Task_FillUploadForm">
        <dc:Bounds x="850" y="268" width="210" height="80" />
      </bpmndi:BPMNShape>
