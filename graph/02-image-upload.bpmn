      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ClientValid" bpmnElement="Gateway_ClientValid" isMarkerVisible="true">
        <dc:Bounds x="1330" y="283" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1313" y="333" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowClientError" bpmnElement="Task_ShowClientError">
        <dc:Bounds x="1450" y="380" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SendMultipartRequest" bpmnElement="Task_SendMultipartRequest">
        <dc:Bounds x="1450" y="188" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowSlowUploadNotice" bpmnElement="Task_ShowSlowUploadNotice">
        <dc:Bounds x="1680" y="100" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_AuthenticateUpload" bpmnElement="Task_AuthenticateUpload">
        <dc:Bounds x="1700" y="188" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_AuthValid" bpmnElement="Gateway_AuthValid" isMarkerVisible="true">
        <dc:Bounds x="1930" y="203" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1926" y="253" width="59" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelValidationStart" bpmnElement="Gateway_ParallelValidationStart">
        <dc:Bounds x="2050" y="203" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2044" y="253" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ValidateMetadata" bpmnElement="Task_ValidateMetadata">
        <dc:Bounds x="2170" y="100" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ValidateFile" bpmnElement="Task_ValidateFile">
        <dc:Bounds x="2170" y="210" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ScanFile" bpmnElement="Task_ScanFile">
        <dc:Bounds x="2170" y="320" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ParallelValidationEnd" bpmnElement="Gateway_ParallelValidationEnd">
        <dc:Bounds x="2420" y="203" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2411" y="253" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ServerValid" bpmnElement="Gateway_ServerValid" isMarkerVisible="true">
        <dc:Bounds x="2540" y="203" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2524" y="253" width="82" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_PrepareBlobName" bpmnElement="Task_PrepareBlobName">
        <dc:Bounds x="2660" y="188" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_UploadBlob" bpmnElement="Task_UploadBlob">
        <dc:Bounds x="2900" y="188" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SaveImageMetadata" bpmnElement="Task_SaveImageMetadata">
        <dc:Bounds x="3150" y="188" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_DeleteBlobCompensation" bpmnElement="Task_DeleteBlobCompensation">
        <dc:Bounds x="3430" y="360" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReturnCreatedImage" bpmnElement="Task_ReturnCreatedImage">
        <dc:Bounds x="3430" y="188" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReturnUploadError" bpmnElement="Task_ReturnUploadError">
        <dc:Bounds x="3690" y="360" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_UpdateUploadList" bpmnElement="Task_UpdateUploadList">
        <dc:Bounds x="3670" y="188" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_UploadSuccess" bpmnElement="End_UploadSuccess">
        <dc:Bounds x="3920" y="210" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3896" y="246" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_UploadFailed" bpmnElement="End_UploadFailed">
        <dc:Bounds x="3930" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3909" y="418" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_ProgressNotice" bpmnElement="End_ProgressNotice">
        <dc:Bounds x="1930" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1910" y="158" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataObject_ImageFile" bpmnElement="DataObject_ImageFile">
        <dc:Bounds x="880" y="170" width="120" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="914" y="240" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataObject_MetadataForm" bpmnElement="DataObject_MetadataForm">
        <dc:Bounds x="1110" y="170" width="120" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1127" y="240" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataObject_BlobUrl" bpmnElement="DataObject_BlobUrl">
        <dc:Bounds x="3130" y="100" width="120" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3166" y="170" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataObject_CreatedImageJson" bpmnElement="DataObject_CreatedImageJson">
        <dc:Bounds x="3440" y="100" width="120" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3463" y="170" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_DataStore_BlobStorage" bpmnElement="DataStore_BlobStorage">
        <dc:Bounds x="2920" y="80" width="140" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2963" y="150" width="54" height="27" />
