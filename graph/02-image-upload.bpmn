<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ImageUpload" targetNamespace="https://ai-art-gallery.example/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:process id="Process_ImageUpload" name="Image Upload, Storage, and Compensation Flow" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ImageUpload">
      <bpmn:lane id="Lane_User" name="User" />
      <bpmn:lane id="Lane_Frontend" name="React Frontend" />
      <bpmn:lane id="Lane_Backend" name=".NET Web API" />
      <bpmn:lane id="Lane_Storage" name="Azure Blob Storage" />
      <bpmn:lane id="Lane_Database" name="Azure SQL Database" />
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_OpenUpload" name="User opens Upload Image page">
      <bpmn:outgoing>Flow_Start_ShowUploads</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ShowUploadedImages" name="Load and show previous uploads">
      <bpmn:incoming>Flow_Start_ShowUploads</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowUploads_ClickUpload</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClickUploadButton" name="Click Upload button">
      <bpmn:incoming>Flow_ShowUploads_ClickUpload</bpmn:incoming>
      <bpmn:outgoing>Flow_ClickUpload_OpenModal</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OpenUploadModal" name="Open upload modal">
      <bpmn:incoming>Flow_ClickUpload_OpenModal</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenModal_FillForm</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FillUploadForm" name="Enter title, tag, platform, description, prompt, and image">
      <bpmn:incoming>Flow_OpenModal_FillForm</bpmn:incoming>
      <bpmn:outgoing>Flow_FillForm_ClientValidation</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClientValidation" name="Validate required fields and file type">
      <bpmn:incoming>Flow_FillForm_ClientValidation</bpmn:incoming>
      <bpmn:outgoing>Flow_ClientValidation_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ClientValid" name="Client form valid?">
      <bpmn:incoming>Flow_ClientValidation_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_ClientValid_SendRequest</bpmn:outgoing>
      <bpmn:outgoing>Flow_ClientInvalid_ShowError</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ShowClientError" name="Show missing field or invalid file message">
      <bpmn:incoming>Flow_ClientInvalid_ShowError</bpmn:incoming>
      <bpmn:outgoing>Flow_ClientError_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SendMultipartRequest" name="POST /api/images multipart request">
      <bpmn:incoming>Flow_ClientValid_SendRequest</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRequest_Authenticate</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="Boundary_SlowUpload" name="Slow upload timer" cancelActivity="false" attachedToRef="Task_SendMultipartRequest">
      <bpmn:outgoing>Flow_SlowUpload_Notice</bpmn:outgoing>
      <bpmn:timerEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_ShowSlowUploadNotice" name="Show non-blocking upload progress notice">
      <bpmn:incoming>Flow_SlowUpload_Notice</bpmn:incoming>
      <bpmn:outgoing>Flow_SlowNotice_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AuthenticateUpload" name="Validate JWT and user ownership context">
      <bpmn:incoming>Flow_SendRequest_Authenticate</bpmn:incoming>
      <bpmn:outgoing>Flow_Authenticate_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AuthValid" name="Authorized?">
      <bpmn:incoming>Flow_Authenticate_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Authorized_ParallelStart</bpmn:outgoing>
      <bpmn:outgoing>Flow_Unauthorized_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Gateway_ParallelValidationStart" name="Start parallel validation">
      <bpmn:incoming>Flow_Authorized_ParallelStart</bpmn:incoming>
      <bpmn:outgoing>Flow_Parallel_Metadata</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_File</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_Scan</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_ValidateMetadata" name="Validate title, tag, description, and prompt">
      <bpmn:incoming>Flow_Parallel_Metadata</bpmn:incoming>
      <bpmn:outgoing>Flow_Metadata_ParallelEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidateFile" name="Validate image extension and size limit">
      <bpmn:incoming>Flow_Parallel_File</bpmn:incoming>
      <bpmn:outgoing>Flow_File_ParallelEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ScanFile" name="Optional file safety scan">
      <bpmn:incoming>Flow_Parallel_Scan</bpmn:incoming>
      <bpmn:outgoing>Flow_Scan_ParallelEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ParallelValidationEnd" name="All validations complete">
      <bpmn:incoming>Flow_Metadata_ParallelEnd</bpmn:incoming>
      <bpmn:incoming>Flow_File_ParallelEnd</bpmn:incoming>
      <bpmn:incoming>Flow_Scan_ParallelEnd</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelEnd_ServerGateway</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Gateway_ServerValid" name="Server validation passed?">
      <bpmn:incoming>Flow_ParallelEnd_ServerGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_ServerValid_PrepareBlob</bpmn:outgoing>
      <bpmn:outgoing>Flow_ServerInvalid_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_PrepareBlobName" name="Generate unique Blob path and file name">
      <bpmn:incoming>Flow_ServerValid_PrepareBlob</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareBlob_Upload</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UploadBlob" name="Upload image bytes to Azure Blob Storage">
      <bpmn:incoming>Flow_PrepareBlob_Upload</bpmn:incoming>
      <bpmn:outgoing>Flow_UploadBlob_SaveMetadata</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="Boundary_BlobUploadError" name="Blob upload error" attachedToRef="Task_UploadBlob">
      <bpmn:outgoing>Flow_BlobError_ReturnError</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_SaveImageMetadata" name="Save Blob URL and metadata to Images table">
      <bpmn:incoming>Flow_UploadBlob_SaveMetadata</bpmn:incoming>
      <bpmn:outgoing>Flow_SaveMetadata_ReturnCreated</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="Boundary_MetadataSaveError" name="SQL save error" attachedToRef="Task_SaveImageMetadata">
      <bpmn:outgoing>Flow_MetadataError_DeleteBlob</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_DeleteBlobCompensation" name="Compensation: delete uploaded Blob">
      <bpmn:incoming>Flow_MetadataError_DeleteBlob</bpmn:incoming>
      <bpmn:outgoing>Flow_DeleteBlob_ReturnError</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReturnCreatedImage" name="Return created image JSON">
      <bpmn:incoming>Flow_SaveMetadata_ReturnCreated</bpmn:incoming>
      <bpmn:outgoing>Flow_ReturnCreated_UpdateUI</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReturnUploadError" name="Return upload error response">
      <bpmn:incoming>Flow_Unauthorized_Error</bpmn:incoming>
      <bpmn:incoming>Flow_ServerInvalid_Error</bpmn:incoming>
      <bpmn:incoming>Flow_BlobError_ReturnError</bpmn:incoming>
      <bpmn:incoming>Flow_DeleteBlob_ReturnError</bpmn:incoming>
      <bpmn:outgoing>Flow_ReturnError_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UpdateUploadList" name="Close modal and prepend uploaded artwork card">
      <bpmn:incoming>Flow_ReturnCreated_UpdateUI</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateUI_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_UploadSuccess" name="Artwork available in gallery">
      <bpmn:incoming>Flow_UpdateUI_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_UploadFailed" name="Upload stopped with feedback">
      <bpmn:incoming>Flow_ClientError_End</bpmn:incoming>
      <bpmn:incoming>Flow_ReturnError_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_ProgressNotice" name="Progress notice displayed">
      <bpmn:incoming>Flow_SlowNotice_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_ShowUploads" sourceRef="Start_OpenUpload" targetRef="Task_ShowUploadedImages" />
    <bpmn:sequenceFlow id="Flow_ShowUploads_ClickUpload" sourceRef="Task_ShowUploadedImages" targetRef="Task_ClickUploadButton" />
    <bpmn:sequenceFlow id="Flow_ClickUpload_OpenModal" sourceRef="Task_ClickUploadButton" targetRef="Task_OpenUploadModal" />
    <bpmn:sequenceFlow id="Flow_OpenModal_FillForm" sourceRef="Task_OpenUploadModal" targetRef="Task_FillUploadForm" />
    <bpmn:sequenceFlow id="Flow_FillForm_ClientValidation" sourceRef="Task_FillUploadForm" targetRef="Task_ClientValidation" />
    <bpmn:sequenceFlow id="Flow_ClientValidation_Gateway" sourceRef="Task_ClientValidation" targetRef="Gateway_ClientValid" />
    <bpmn:sequenceFlow id="Flow_ClientValid_SendRequest" name="Valid" sourceRef="Gateway_ClientValid" targetRef="Task_SendMultipartRequest" />
    <bpmn:sequenceFlow id="Flow_ClientInvalid_ShowError" name="Invalid" sourceRef="Gateway_ClientValid" targetRef="Task_ShowClientError" />
    <bpmn:sequenceFlow id="Flow_ClientError_End" sourceRef="Task_ShowClientError" targetRef="End_UploadFailed" />
    <bpmn:sequenceFlow id="Flow_SlowUpload_Notice" sourceRef="Boundary_SlowUpload" targetRef="Task_ShowSlowUploadNotice" />
    <bpmn:sequenceFlow id="Flow_SlowNotice_End" sourceRef="Task_ShowSlowUploadNotice" targetRef="End_ProgressNotice" />
    <bpmn:sequenceFlow id="Flow_SendRequest_Authenticate" sourceRef="Task_SendMultipartRequest" targetRef="Task_AuthenticateUpload" />
    <bpmn:sequenceFlow id="Flow_Authenticate_Gateway" sourceRef="Task_AuthenticateUpload" targetRef="Gateway_AuthValid" />
    <bpmn:sequenceFlow id="Flow_Authorized_ParallelStart" name="Authorized" sourceRef="Gateway_AuthValid" targetRef="Gateway_ParallelValidationStart" />
    <bpmn:sequenceFlow id="Flow_Unauthorized_Error" name="Unauthorized" sourceRef="Gateway_AuthValid" targetRef="Task_ReturnUploadError" />
    <bpmn:sequenceFlow id="Flow_Parallel_Metadata" sourceRef="Gateway_ParallelValidationStart" targetRef="Task_ValidateMetadata" />
    <bpmn:sequenceFlow id="Flow_Parallel_File" sourceRef="Gateway_ParallelValidationStart" targetRef="Task_ValidateFile" />
    <bpmn:sequenceFlow id="Flow_Parallel_Scan" sourceRef="Gateway_ParallelValidationStart" targetRef="Task_ScanFile" />
    <bpmn:sequenceFlow id="Flow_Metadata_ParallelEnd" sourceRef="Task_ValidateMetadata" targetRef="Gateway_ParallelValidationEnd" />
    <bpmn:sequenceFlow id="Flow_File_ParallelEnd" sourceRef="Task_ValidateFile" targetRef="Gateway_ParallelValidationEnd" />
    <bpmn:sequenceFlow id="Flow_Scan_ParallelEnd" sourceRef="Task_ScanFile" targetRef="Gateway_ParallelValidationEnd" />
    <bpmn:sequenceFlow id="Flow_ParallelEnd_ServerGateway" sourceRef="Gateway_ParallelValidationEnd" targetRef="Gateway_ServerValid" />
    <bpmn:sequenceFlow id="Flow_ServerValid_PrepareBlob" name="Passed" sourceRef="Gateway_ServerValid" targetRef="Task_PrepareBlobName" />
    <bpmn:sequenceFlow id="Flow_ServerInvalid_Error" name="Failed" sourceRef="Gateway_ServerValid" targetRef="Task_ReturnUploadError" />
    <bpmn:sequenceFlow id="Flow_PrepareBlob_Upload" sourceRef="Task_PrepareBlobName" targetRef="Task_UploadBlob" />
    <bpmn:sequenceFlow id="Flow_UploadBlob_SaveMetadata" sourceRef="Task_UploadBlob" targetRef="Task_SaveImageMetadata" />
    <bpmn:sequenceFlow id="Flow_BlobError_ReturnError" sourceRef="Boundary_BlobUploadError" targetRef="Task_ReturnUploadError" />
    <bpmn:sequenceFlow id="Flow_SaveMetadata_ReturnCreated" sourceRef="Task_SaveImageMetadata" targetRef="Task_ReturnCreatedImage" />
    <bpmn:sequenceFlow id="Flow_MetadataError_DeleteBlob" sourceRef="Boundary_MetadataSaveError" targetRef="Task_DeleteBlobCompensation" />
    <bpmn:sequenceFlow id="Flow_DeleteBlob_ReturnError" sourceRef="Task_DeleteBlobCompensation" targetRef="Task_ReturnUploadError" />
    <bpmn:sequenceFlow id="Flow_ReturnCreated_UpdateUI" sourceRef="Task_ReturnCreatedImage" targetRef="Task_UpdateUploadList" />
    <bpmn:sequenceFlow id="Flow_ReturnError_End" sourceRef="Task_ReturnUploadError" targetRef="End_UploadFailed" />
    <bpmn:sequenceFlow id="Flow_UpdateUI_End" sourceRef="Task_UpdateUploadList" targetRef="End_UploadSuccess" />
    <bpmn:dataObjectReference id="DataObject_ImageFile" name="Image File" />
    <bpmn:dataObjectReference id="DataObject_MetadataForm" name="Artwork Metadata" />
    <bpmn:dataObjectReference id="DataObject_BlobUrl" name="Blob URL" />
    <bpmn:dataObjectReference id="DataObject_CreatedImageJson" name="Created Image JSON" />
    <bpmn:dataStoreReference id="DataStore_BlobStorage" name="Azure Blob Container" />
    <bpmn:dataStoreReference id="DataStore_ImagesTable" name="Images Table" />
    <bpmn:association id="Association_Task_FillUploadForm_DataObject_ImageFile" sourceRef="Task_FillUploadForm" targetRef="DataObject_ImageFile" />
    <bpmn:association id="Association_Task_ClientValidation_DataObject_MetadataForm" sourceRef="Task_ClientValidation" targetRef="DataObject_MetadataForm" />
    <bpmn:association id="Association_Task_UploadBlob_DataObject_BlobUrl" sourceRef="Task_UploadBlob" targetRef="DataObject_BlobUrl" />
    <bpmn:association id="Association_Task_ReturnCreatedImage_DataObject_CreatedImageJson" sourceRef="Task_ReturnCreatedImage" targetRef="DataObject_CreatedImageJson" />
    <bpmn:association id="Association_Task_UploadBlob_DataStore_BlobStorage" sourceRef="Task_UploadBlob" targetRef="DataStore_BlobStorage" />
    <bpmn:association id="Association_Task_SaveImageMetadata_DataStore_ImagesTable" sourceRef="Task_SaveImageMetadata" targetRef="DataStore_ImagesTable" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_ImageUpload">
    <bpmndi:BPMNPlane id="Plane_ImageUpload" bpmnElement="Process_ImageUpload">
      <bpmndi:BPMNShape id="Shape_Start_OpenUpload" bpmnElement="Start_OpenUpload">
        <dc:Bounds x="170" y="290" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="153" y="326" width="70" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowUploadedImages" bpmnElement="Task_ShowUploadedImages">
        <dc:Bounds x="240" y="268" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ClickUploadButton" bpmnElement="Task_ClickUploadButton">
        <dc:Bounds x="460" y="268" width="140" height="80" />
      </bpmndi:BPMNShape>
