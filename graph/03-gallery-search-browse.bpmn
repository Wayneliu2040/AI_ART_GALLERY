        <di:waypoint x="3025" y="120" />
        <di:waypoint x="3025" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Association_Task_ReadImageList_Store_Gallery" bpmnElement="Association_Task_ReadImageList_Store_Gallery">
        <di:waypoint x="1430" y="210" />
        <di:waypoint x="1422" y="200" />
        <di:waypoint x="1415" y="190" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>