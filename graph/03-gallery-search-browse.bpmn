        <di:waypoint x="1790" y="200" />
        <di:waypoint x="1785" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Association_Task_RenderDetail_Data_DetailDto" bpmnElement="Association_Task_RenderDetail_Data_DetailDto">
