        <di:waypoint x="3180" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Association_Task_BuildParams_Data_Query" bpmnElement="Association_Task_BuildParams_Data_Query">
        <di:waypoint x="700" y="210" />
        <di:waypoint x="695" y="200" />
        <di:waypoint x="690" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Association_Task_ShowCards_Data_ListDto" bpmnElement="Association_Task_ShowCards_Data_ListDto">
