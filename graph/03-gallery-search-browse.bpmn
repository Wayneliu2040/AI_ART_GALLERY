<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Process_GalleryBrowse" targetNamespace="https://ai-art-gallery.example/bpmn">
  <bpmn:process id="Process_GalleryBrowse" name="Current Gallery Browse, Search, and Detail Flow" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_GalleryBrowse">
      <bpmn:lane id="Lane_User" name="User">
        <bpmn:flowNodeRef>Start_Gallery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SearchOrTag</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClickDetails</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Frontend" name="React Frontend">
        <bpmn:flowNodeRef>Task_RenderGallery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BuildParams</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestImages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ImagesFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowNoResults</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowCards</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestDetail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RenderDetail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowDetailError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_BrowseReady</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Backend" name=".NET Web API">
        <bpmn:flowNodeRef>Task_QueryImages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryImageById</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ImageExists</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Data" name="Azure SQL Database">
        <bpmn:flowNodeRef>Task_ReadImageList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReadImageDetail</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Gallery" name="Open Explore page">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_RenderGallery" name="Render search bar and tag filters">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SearchOrTag" name="Enter keyword or select tag">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BuildParams" name="Build q and tag query params">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RequestImages" name="GET /api/images?q=&amp;tag=">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QueryImages" name="Apply keyword and tag filters">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReadImageList" name="Read Images with Users, Likes, Comments">
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:outgoing>F7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ImagesFound" name="Images found?">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:outgoing>F8</bpmn:outgoing>
      <bpmn:outgoing>F9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ShowNoResults" name="Show no images found state">
      <bpmn:incoming>F8</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowCards" name="Render artwork cards">
      <bpmn:incoming>F9</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClickDetails" name="Click View Details">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:outgoing>F12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RequestDetail" name="GET /api/images/{id}">
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QueryImageById" name="Find image by id">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ImageExists" name="Image exists?">
      <bpmn:incoming>F14</bpmn:incoming>
      <bpmn:outgoing>F15</bpmn:outgoing>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ReadImageDetail" name="Read detail with comments and likes">
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RenderDetail" name="Render detail page">
      <bpmn:incoming>F17</bpmn:incoming>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowDetailError" name="Show image not found error">
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_BrowseReady" name="Browse flow complete">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:incoming>F19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_Gallery" targetRef="Task_RenderGallery" />
    <bpmn:sequenceFlow id="F2" sourceRef="Task_RenderGallery" targetRef="Task_SearchOrTag" />
    <bpmn:sequenceFlow id="F3" sourceRef="Task_SearchOrTag" targetRef="Task_BuildParams" />
    <bpmn:sequenceFlow id="F4" sourceRef="Task_BuildParams" targetRef="Task_RequestImages" />
    <bpmn:sequenceFlow id="F5" sourceRef="Task_RequestImages" targetRef="Task_QueryImages" />
    <bpmn:sequenceFlow id="F6" sourceRef="Task_QueryImages" targetRef="Task_ReadImageList" />
    <bpmn:sequenceFlow id="F7" sourceRef="Task_ReadImageList" targetRef="Gateway_ImagesFound" />
    <bpmn:sequenceFlow id="F8" sourceRef="Gateway_ImagesFound" targetRef="Task_ShowNoResults" name="No" />
    <bpmn:sequenceFlow id="F9" sourceRef="Gateway_ImagesFound" targetRef="Task_ShowCards" name="Yes" />
    <bpmn:sequenceFlow id="F10" sourceRef="Task_ShowNoResults" targetRef="End_BrowseReady" />
    <bpmn:sequenceFlow id="F11" sourceRef="Task_ShowCards" targetRef="Task_ClickDetails" />
    <bpmn:sequenceFlow id="F12" sourceRef="Task_ClickDetails" targetRef="Task_RequestDetail" />
    <bpmn:sequenceFlow id="F13" sourceRef="Task_RequestDetail" targetRef="Task_QueryImageById" />
    <bpmn:sequenceFlow id="F14" sourceRef="Task_QueryImageById" targetRef="Gateway_ImageExists" />
    <bpmn:sequenceFlow id="F15" sourceRef="Gateway_ImageExists" targetRef="Task_ReadImageDetail" name="Yes" />
    <bpmn:sequenceFlow id="F16" sourceRef="Gateway_ImageExists" targetRef="Task_ShowDetailError" name="No" />
    <bpmn:sequenceFlow id="F17" sourceRef="Task_ReadImageDetail" targetRef="Task_RenderDetail" />
    <bpmn:sequenceFlow id="F18" sourceRef="Task_RenderDetail" targetRef="End_BrowseReady" />
    <bpmn:sequenceFlow id="F19" sourceRef="Task_ShowDetailError" targetRef="End_BrowseReady" />
    <bpmn:dataObjectReference id="Data_Query" name="q + tag Query" />
    <bpmn:association id="Association_Task_BuildParams_Data_Query" sourceRef="Task_BuildParams" targetRef="Data_Query" />
    <bpmn:dataObjectReference id="Data_ListDto" name="Image List DTOs" />
    <bpmn:association id="Association_Task_ShowCards_Data_ListDto" sourceRef="Task_ShowCards" targetRef="Data_ListDto" />
    <bpmn:dataObjectReference id="Data_DetailDto" name="Image Detail DTO" />
    <bpmn:association id="Association_Task_RenderDetail_Data_DetailDto" sourceRef="Task_RenderDetail" targetRef="Data_DetailDto" />
    <bpmn:dataStoreReference id="Store_Gallery" name="Images / Users / Likes / Comments" />
    <bpmn:association id="Association_Task_ReadImageList_Store_Gallery" sourceRef="Task_ReadImageList" targetRef="Store_Gallery" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_Process_GalleryBrowse">
    <bpmndi:BPMNPlane id="Plane_Process_GalleryBrowse" bpmnElement="Process_GalleryBrowse">
      <bpmndi:BPMNShape id="Shape_Start_Gallery" bpmnElement="Start_Gallery">
        <dc:Bounds x="70" y="230" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RenderGallery" bpmnElement="Task_RenderGallery">
        <dc:Bounds x="140" y="210" width="190" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SearchOrTag" bpmnElement="Task_SearchOrTag">
        <dc:Bounds x="380" y="210" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_BuildParams" bpmnElement="Task_BuildParams">
        <dc:Bounds x="610" y="210" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RequestImages" bpmnElement="Task_RequestImages">
        <dc:Bounds x="840" y="210" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_QueryImages" bpmnElement="Task_QueryImages">
        <dc:Bounds x="1070" y="210" width="190" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReadImageList" bpmnElement="Task_ReadImageList">
        <dc:Bounds x="1320" y="210" width="220" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ImagesFound" bpmnElement="Gateway_ImagesFound">
        <dc:Bounds x="1600" y="220" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowNoResults" bpmnElement="Task_ShowNoResults">
        <dc:Bounds x="1710" y="330" width="180" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowCards" bpmnElement="Task_ShowCards">
        <dc:Bounds x="1710" y="210" width="170" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ClickDetails" bpmnElement="Task_ClickDetails">
        <dc:Bounds x="1940" y="210" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RequestDetail" bpmnElement="Task_RequestDetail">
        <dc:Bounds x="2140" y="210" width="170" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_QueryImageById" bpmnElement="Task_QueryImageById">
        <dc:Bounds x="2360" y="210" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ImageExists" bpmnElement="Gateway_ImageExists">
        <dc:Bounds x="2570" y="220" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReadImageDetail" bpmnElement="Task_ReadImageDetail">
        <dc:Bounds x="2680" y="130" width="210" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RenderDetail" bpmnElement="Task_RenderDetail">
        <dc:Bounds x="2940" y="130" width="170" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowDetailError" bpmnElement="Task_ShowDetailError">
        <dc:Bounds x="2680" y="330" width="190" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_BrowseReady" bpmnElement="End_BrowseReady">
        <dc:Bounds x="3180" y="147" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_Query" bpmnElement="Data_Query">
        <dc:Bounds x="630" y="130" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_ListDto" bpmnElement="Data_ListDto">
        <dc:Bounds x="1720" y="130" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Data_DetailDto" bpmnElement="Data_DetailDto">
        <dc:Bounds x="2960" y="50" width="130" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Store_Gallery" bpmnElement="Store_Gallery">
        <dc:Bounds x="1330" y="130" width="170" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_F1" bpmnElement="F1">
        <di:waypoint x="106" y="248" />
        <di:waypoint x="123" y="248" />
        <di:waypoint x="123" y="245" />
        <di:waypoint x="140" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F2" bpmnElement="F2">
        <di:waypoint x="330" y="245" />
        <di:waypoint x="355" y="245" />
        <di:waypoint x="380" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F3" bpmnElement="F3">
        <di:waypoint x="560" y="245" />
        <di:waypoint x="585" y="245" />
        <di:waypoint x="610" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F4" bpmnElement="F4">
        <di:waypoint x="790" y="245" />
        <di:waypoint x="815" y="245" />
        <di:waypoint x="840" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F5" bpmnElement="F5">
        <di:waypoint x="1020" y="245" />
        <di:waypoint x="1045" y="245" />
        <di:waypoint x="1070" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F6" bpmnElement="F6">
        <di:waypoint x="1260" y="245" />
        <di:waypoint x="1290" y="245" />
        <di:waypoint x="1320" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F7" bpmnElement="F7">
        <di:waypoint x="1540" y="245" />
        <di:waypoint x="1570" y="245" />
        <di:waypoint x="1600" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F8" bpmnElement="F8">
        <di:waypoint x="1650" y="245" />
        <di:waypoint x="1680" y="245" />
        <di:waypoint x="1680" y="365" />
        <di:waypoint x="1710" y="365" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F9" bpmnElement="F9">
        <di:waypoint x="1650" y="245" />
        <di:waypoint x="1680" y="245" />
        <di:waypoint x="1710" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F10" bpmnElement="F10">
        <di:waypoint x="1890" y="365" />
        <di:waypoint x="2535" y="365" />
        <di:waypoint x="2535" y="165" />
        <di:waypoint x="3180" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F11" bpmnElement="F11">
        <di:waypoint x="1880" y="245" />
        <di:waypoint x="1910" y="245" />
        <di:waypoint x="1940" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F12" bpmnElement="F12">
        <di:waypoint x="2090" y="245" />
        <di:waypoint x="2115" y="245" />
        <di:waypoint x="2140" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F13" bpmnElement="F13">
        <di:waypoint x="2310" y="245" />
        <di:waypoint x="2335" y="245" />
        <di:waypoint x="2360" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F14" bpmnElement="F14">
        <di:waypoint x="2510" y="245" />
        <di:waypoint x="2540" y="245" />
        <di:waypoint x="2570" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F15" bpmnElement="F15">
        <di:waypoint x="2620" y="245" />
        <di:waypoint x="2650" y="245" />
        <di:waypoint x="2650" y="165" />
        <di:waypoint x="2680" y="165" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F16" bpmnElement="F16">
        <di:waypoint x="2620" y="245" />
        <di:waypoint x="2650" y="245" />
        <di:waypoint x="2650" y="365" />
        <di:waypoint x="2680" y="365" />
      </bpmndi:BPMNEdge>
