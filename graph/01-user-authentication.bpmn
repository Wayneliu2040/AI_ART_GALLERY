<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_UserAuthentication" targetNamespace="https://ai-art-gallery.example/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:process id="Process_UserAuthentication" name="User Authentication Flow" isExecutable="false">
    <bpmn:startEvent id="Start_OpenApp" name="User opens AI Art Gallery">
      <bpmn:outgoing>Flow_Start_To_OpenAuth</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_OpenAuthPage" name="Open login or register page">
      <bpmn:incoming>Flow_Start_To_OpenAuth</bpmn:incoming>
      <bpmn:outgoing>Flow_OpenAuth_To_AccountGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_HasAccount" name="Existing account?">
      <bpmn:incoming>Flow_OpenAuth_To_AccountGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_HasAccount_To_Login</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoAccount_To_Register</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SubmitLogin" name="Submit login credentials">
      <bpmn:incoming>Flow_HasAccount_To_Login</bpmn:incoming>
      <bpmn:outgoing>Flow_Login_To_Validate</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidateCredentials" name="Backend validates email and password">
      <bpmn:incoming>Flow_Login_To_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_To_AuthGateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AuthValid" name="Authentication valid?">
      <bpmn:incoming>Flow_Validate_To_AuthGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthValid_To_Token</bpmn:outgoing>
      <bpmn:outgoing>Flow_AuthInvalid_To_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SubmitRegister" name="Submit registration form">
      <bpmn:incoming>Flow_NoAccount_To_Register</bpmn:incoming>
      <bpmn:outgoing>Flow_Register_To_CreateUser</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CreateUser" name="Create user in Azure SQL Database">
      <bpmn:incoming>Flow_Register_To_CreateUser</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateUser_To_Token</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReturnToken" name="Return JWT and user profile">
      <bpmn:incoming>Flow_AuthValid_To_Token</bpmn:incoming>
      <bpmn:incoming>Flow_CreateUser_To_Token</bpmn:incoming>
      <bpmn:outgoing>Flow_Token_To_SaveSession</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SaveSession" name="Frontend stores session and user data">
      <bpmn:incoming>Flow_Token_To_SaveSession</bpmn:incoming>
      <bpmn:outgoing>Flow_SaveSession_To_Gallery</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowAuthError" name="Show login error message">
      <bpmn:incoming>Flow_AuthInvalid_To_Error</bpmn:incoming>
      <bpmn:outgoing>Flow_Error_To_FailedEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_AccessGallery" name="User enters Explore page">
      <bpmn:incoming>Flow_SaveSession_To_Gallery</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_LoginFailed" name="Authentication failed">
      <bpmn:incoming>Flow_Error_To_FailedEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_OpenAuth" sourceRef="Start_OpenApp" targetRef="Task_OpenAuthPage" />
    <bpmn:sequenceFlow id="Flow_OpenAuth_To_AccountGateway" sourceRef="Task_OpenAuthPage" targetRef="Gateway_HasAccount" />
    <bpmn:sequenceFlow id="Flow_HasAccount_To_Login" name="Yes" sourceRef="Gateway_HasAccount" targetRef="Task_SubmitLogin" />
    <bpmn:sequenceFlow id="Flow_NoAccount_To_Register" name="No" sourceRef="Gateway_HasAccount" targetRef="Task_SubmitRegister" />
    <bpmn:sequenceFlow id="Flow_Login_To_Validate" sourceRef="Task_SubmitLogin" targetRef="Task_ValidateCredentials" />
    <bpmn:sequenceFlow id="Flow_Validate_To_AuthGateway" sourceRef="Task_ValidateCredentials" targetRef="Gateway_AuthValid" />
    <bpmn:sequenceFlow id="Flow_AuthValid_To_Token" name="Valid" sourceRef="Gateway_AuthValid" targetRef="Task_ReturnToken" />
    <bpmn:sequenceFlow id="Flow_AuthInvalid_To_Error" name="Invalid" sourceRef="Gateway_AuthValid" targetRef="Task_ShowAuthError" />
    <bpmn:sequenceFlow id="Flow_Register_To_CreateUser" sourceRef="Task_SubmitRegister" targetRef="Task_CreateUser" />
    <bpmn:sequenceFlow id="Flow_CreateUser_To_Token" sourceRef="Task_CreateUser" targetRef="Task_ReturnToken" />
    <bpmn:sequenceFlow id="Flow_Token_To_SaveSession" sourceRef="Task_ReturnToken" targetRef="Task_SaveSession" />
    <bpmn:sequenceFlow id="Flow_SaveSession_To_Gallery" sourceRef="Task_SaveSession" targetRef="End_AccessGallery" />
    <bpmn:sequenceFlow id="Flow_Error_To_FailedEnd" sourceRef="Task_ShowAuthError" targetRef="End_LoginFailed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_UserAuthentication">
    <bpmndi:BPMNPlane id="Plane_UserAuthentication" bpmnElement="Process_UserAuthentication">
      <bpmndi:BPMNShape id="Shape_Start_OpenApp" bpmnElement="Start_OpenApp">
        <dc:Bounds x="180" y="190" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="155" y="226" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_OpenAuthPage" bpmnElement="Task_OpenAuthPage">
        <dc:Bounds x="260" y="168" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_HasAccount" bpmnElement="Gateway_HasAccount" isMarkerVisible="true">
        <dc:Bounds x="440" y="183" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="422" y="233" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SubmitLogin" bpmnElement="Task_SubmitLogin">
        <dc:Bounds x="550" y="88" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ValidateCredentials" bpmnElement="Task_ValidateCredentials">
        <dc:Bounds x="750" y="88" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_AuthValid" bpmnElement="Gateway_AuthValid" isMarkerVisible="true">
        <dc:Bounds x="970" y="103" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="960" y="153" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SubmitRegister" bpmnElement="Task_SubmitRegister">
        <dc:Bounds x="550" y="288" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CreateUser" bpmnElement="Task_CreateUser">
        <dc:Bounds x="750" y="288" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReturnToken" bpmnElement="Task_ReturnToken">
        <dc:Bounds x="1090" y="188" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SaveSession" bpmnElement="Task_SaveSession">
        <dc:Bounds x="1300" y="188" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ShowAuthError" bpmnElement="Task_ShowAuthError">
        <dc:Bounds x="1090" y="48" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_AccessGallery" bpmnElement="End_AccessGallery">
        <dc:Bounds x="1530" y="210" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1515" y="246" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_LoginFailed" bpmnElement="End_LoginFailed">
        <dc:Bounds x="1300" y="70" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1283" y="106" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_OpenAuth" bpmnElement="Flow_Start_To_OpenAuth">
        <di:waypoint x="216" y="208" />
        <di:waypoint x="260" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OpenAuth_To_AccountGateway" bpmnElement="Flow_OpenAuth_To_AccountGateway">
        <di:waypoint x="390" y="208" />
        <di:waypoint x="440" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_HasAccount_To_Login" bpmnElement="Flow_HasAccount_To_Login">
        <di:waypoint x="465" y="183" />
        <di:waypoint x="465" y="128" />
        <di:waypoint x="550" y="128" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="471" y="146" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_NoAccount_To_Register" bpmnElement="Flow_NoAccount_To_Register">
        <di:waypoint x="465" y="233" />
        <di:waypoint x="465" y="328" />
        <di:waypoint x="550" y="328" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="473" y="271" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Login_To_Validate" bpmnElement="Flow_Login_To_Validate">
        <di:waypoint x="690" y="128" />
        <di:waypoint x="750" y="128" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Validate_To_AuthGateway" bpmnElement="Flow_Validate_To_AuthGateway">
        <di:waypoint x="910" y="128" />
        <di:waypoint x="970" y="128" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_AuthValid_To_Token" bpmnElement="Flow_AuthValid_To_Token">
        <di:waypoint x="1020" y="128" />
        <di:waypoint x="1055" y="128" />
        <di:waypoint x="1055" y="228" />
        <di:waypoint x="1090" y="228" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1059" y="168" width="23" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_AuthInvalid_To_Error" bpmnElement="Flow_AuthInvalid_To_Error">
        <di:waypoint x="1020" y="128" />
        <di:waypoint x="1055" y="128" />
        <di:waypoint x="1055" y="88" />
        <di:waypoint x="1090" y="88" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1054" y="98" width="32" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Register_To_CreateUser" bpmnElement="Flow_Register_To_CreateUser">
        <di:waypoint x="690" y="328" />
        <di:waypoint x="750" y="328" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CreateUser_To_Token" bpmnElement="Flow_CreateUser_To_Token">
        <di:waypoint x="910" y="328" />
        <di:waypoint x="1055" y="328" />
        <di:waypoint x="1055" y="228" />
        <di:waypoint x="1090" y="228" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Token_To_SaveSession" bpmnElement="Flow_Token_To_SaveSession">
        <di:waypoint x="1240" y="228" />
        <di:waypoint x="1300" y="228" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SaveSession_To_Gallery" bpmnElement="Flow_SaveSession_To_Gallery">
        <di:waypoint x="1470" y="228" />
        <di:waypoint x="1530" y="228" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Error_To_FailedEnd" bpmnElement="Flow_Error_To_FailedEnd">
        <di:waypoint x="1240" y="88" />
        <di:waypoint x="1300" y="88" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
