<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Process_StaticWebAppDeployment" targetNamespace="https://ai-art-gallery.example/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:process id="Process_StaticWebAppDeployment" name="Current GitHub to Azure Static Web Apps Deployment Flow" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_StaticWebAppDeployment">
      <bpmn:lane id="Lane_Developer" name="Developer and Codex" />
      <bpmn:lane id="Lane_GitHub" name="GitHub Repository and Actions" />
      <bpmn:lane id="Lane_Azure" name="Azure Static Web Apps" />
      <bpmn:lane id="Lane_Validation" name="Validation" />
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_CodeChange" name="Code update ready">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_GitStatus" name="Check git status">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Commit" name="Commit changes">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Push" name="Push main to GitHub">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReceivePush" name="GitHub receives push to main">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Checkout" name="actions/checkout">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Oidc" name="Get GitHub OIDC token">
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:outgoing>F7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AzureDeployAction" name="Run Azure/static-web-apps-deploy@v1">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:outgoing>F8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BuildFrontend" name="Build frontend from ./frontend">
      <bpmn:incoming>F8</bpmn:incoming>
      <bpmn:outgoing>F9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DeployDist" name="Deploy dist output to Static Web Apps">
      <bpmn:incoming>F9</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ActionSuccess" name="Workflow succeeded?">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
      <bpmn:outgoing>F12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ShowActionsError" name="Show GitHub Actions failure">
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_OpenSite" name="Open Azure Static Web Apps URL">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:incoming>F19</bpmn:incoming>
      <bpmn:outgoing>F13</bpmn:outgoing>
      <bpmn:outgoing>Flow_131l1a0</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_UpdateVisible" name="Expected update visible?">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
      <bpmn:outgoing>F15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CheckLogs" name="Check Actions logs">
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClosePrPreview" name="Close PR preview environment">
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Deployed" name="Deployment verified">
      <bpmn:incoming>F14</bpmn:incoming>
      <bpmn:incoming>Flow_131l1a0</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_NeedsFix" name="Needs code/config fix">
      <bpmn:incoming>F17</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_CodeChange" targetRef="Task_GitStatus" />
    <bpmn:sequenceFlow id="F2" sourceRef="Task_GitStatus" targetRef="Task_Commit" />
    <bpmn:sequenceFlow id="F3" sourceRef="Task_Commit" targetRef="Task_Push" />
    <bpmn:sequenceFlow id="F4" sourceRef="Task_Push" targetRef="Task_ReceivePush" />
    <bpmn:sequenceFlow id="F5" sourceRef="Task_ReceivePush" targetRef="Task_Checkout" />
    <bpmn:sequenceFlow id="F6" sourceRef="Task_Checkout" targetRef="Task_Oidc" />
    <bpmn:sequenceFlow id="F7" sourceRef="Task_Oidc" targetRef="Task_AzureDeployAction" />
    <bpmn:sequenceFlow id="F8" sourceRef="Task_AzureDeployAction" targetRef="Task_BuildFrontend" />
    <bpmn:sequenceFlow id="F9" sourceRef="Task_BuildFrontend" targetRef="Task_DeployDist" />
    <bpmn:sequenceFlow id="F10" sourceRef="Task_DeployDist" targetRef="Gateway_ActionSuccess" />
    <bpmn:sequenceFlow id="F11" name="Yes" sourceRef="Gateway_ActionSuccess" targetRef="Task_OpenSite" />
    <bpmn:sequenceFlow id="F12" name="No" sourceRef="Gateway_ActionSuccess" targetRef="Task_ShowActionsError" />
    <bpmn:sequenceFlow id="F13" sourceRef="Task_OpenSite" targetRef="Gateway_UpdateVisible" />
    <bpmn:sequenceFlow id="F14" name="Yes" sourceRef="Gateway_UpdateVisible" targetRef="End_Deployed" />
    <bpmn:sequenceFlow id="F15" name="No" sourceRef="Gateway_UpdateVisible" targetRef="Task_CheckLogs" />
    <bpmn:sequenceFlow id="F16" sourceRef="Task_ShowActionsError" targetRef="Task_CheckLogs" />
    <bpmn:sequenceFlow id="F17" sourceRef="Task_CheckLogs" targetRef="End_NeedsFix" />
    <bpmn:sequenceFlow id="F18" name="PR closed event" sourceRef="Task_ReceivePush" targetRef="Task_ClosePrPreview" />
    <bpmn:sequenceFlow id="F19" sourceRef="Task_ClosePrPreview" targetRef="Task_OpenSite" />
    <bpmn:dataObjectReference id="Data_Commit" name="Git Commit" />
    <bpmn:dataObjectReference id="Data_Workflow" name="Azure SWA Workflow YAML" />
    <bpmn:dataObjectReference id="Data_Dist" name="dist Artifact" />
    <bpmn:dataObjectReference id="Data_Logs" name="Actions Logs" />
    <bpmn:dataStoreReference id="Store_Repo" name="GitHub Repository" />
    <bpmn:dataStoreReference id="Store_Swa" name="Azure Static Web Apps" />
    <bpmn:sequenceFlow id="Flow_131l1a0" sourceRef="Task_OpenSite" targetRef="End_Deployed" />
    <bpmn:association id="Association_Task_Commit_Data_Commit" sourceRef="Task_Commit" targetRef="Data_Commit" />
    <bpmn:association id="Association_Task_AzureDeployAction_Data_Workflow" sourceRef="Task_AzureDeployAction" targetRef="Data_Workflow" />
    <bpmn:association id="Association_Task_DeployDist_Data_Dist" sourceRef="Task_DeployDist" targetRef="Data_Dist" />
    <bpmn:association id="Association_Task_CheckLogs_Data_Logs" sourceRef="Task_CheckLogs" targetRef="Data_Logs" />
    <bpmn:association id="Association_Task_ReceivePush_Store_Repo" sourceRef="Task_ReceivePush" targetRef="Store_Repo" />
    <bpmn:association id="Association_Task_DeployDist_Store_Swa" sourceRef="Task_DeployDist" targetRef="Store_Swa" />
  </bpmn:process>
